# SmartSpend — Environment variables template
# Copy this file to .env and fill in your own values.
# The real .env is gitignored and never committed.

# ============================================================
# Supabase
# ============================================================
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY

# ============================================================
# Sentry
# ============================================================
SENTRY_DSN=https://YOUR_DSN@oXXXXXX.ingest.YOUR_REGION.sentry.io/YOUR_PROJECT_ID
SENTRY_RELEASE=dev
SENTRY_ENVIRONMENT=development

# ============================================================
# Google OAuth Client IDs
# ============================================================
GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com

# ============================================================
# Build metadata
# ============================================================
APP_FLAVOR=development

# ============================================================
# Secrets that DO NOT belong in this file
# ============================================================
# - GEMINI_API_KEY: lives only in Supabase Edge Function secrets
# - Supabase service_role / "secret" key: dashboard + Edge Functions only
# - Sentry Auth Token: CI/CD environment only (Codemagic)
# - Apple credentials: CI/CD environment only
# - Google Web Client SECRET: Supabase dashboard only
