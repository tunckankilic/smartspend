# SmartSpend — Environment variables template
# Copy this file to .env and fill in your own values.
# The real .env is gitignored and never committed.

# ============================================================
# Supabase
# ============================================================
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY

# ============================================================
# Sentry
# ============================================================
SENTRY_DSN=https://YOUR_DSN@oXXXXXX.ingest.YOUR_REGION.sentry.io/YOUR_PROJECT_ID
SENTRY_RELEASE=dev
SENTRY_ENVIRONMENT=development

# ============================================================
# Build metadata
# ============================================================
APP_FLAVOR=development

# ============================================================
# Secrets that DO NOT belong in this file
# ============================================================
# - GEMINI_API_KEY: lives only in Supabase Edge Function secrets
# - Supabase service_role / "secret" key: dashboard + Edge Functions only
# - Sentry Auth Token: local env or CI/CD only (needed by sentry_dart_plugin)
# - Apple credentials: signing/CI only
